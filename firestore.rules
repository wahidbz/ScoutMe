rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // User profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
    }

    // Talent details
    match /talents/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isOwner(userId);
    }

    // Transfers
    match /transfers/{transferId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.clubId || 
        request.auth.uid == resource.data.playerId
      );
      allow create: if isSignedIn() && request.resource.data.clubId == request.auth.uid;
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.clubId || 
        request.auth.uid == resource.data.playerId
      );
    }

    // Chats & Messages
    match /conversations/{convId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.members;
      allow write: if isSignedIn() && request.auth.uid in request.resource.data.members;
    }

    match /messages/{msgId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
    }

    // Public datasets
    match /hall_of_fame/{docId} {
      allow read: if isSignedIn();
      allow write: if false; // Read-only for users
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow update: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn();
    }

    // Economy
    match /mining_sessions/{userId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }

    match /spin_rewards/{userId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }
  }
}
