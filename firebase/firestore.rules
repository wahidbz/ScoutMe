rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isClub() {
      return signedIn() && userDoc(request.auth.uid).data.role == 'club';
    }

    function isPlayer() {
      return signedIn() && userDoc(request.auth.uid).data.role == 'player';
    }

    match /users/{uid} {
      allow read: if signedIn();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if false;
    }

    match /talents/{uid} {
      allow read: if signedIn();
      allow create, update: if isOwner(uid);
      allow delete: if false;
    }

    match /transfers/{transferId} {
      allow read: if signedIn();
      allow create: if isClub() && request.resource.data.clubId == request.auth.uid;
      allow update: if signedIn() && (
        (resource.data.playerId == request.auth.uid && request.resource.data.status in ['accepted', 'rejected']) ||
        (resource.data.clubId == request.auth.uid && request.resource.data.status == 'completed')
      );
      allow delete: if false;
    }

    match /messages/{messageId} {
      allow read: if signedIn() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId);
      allow create: if signedIn() && (request.auth.uid == request.resource.data.senderId || request.auth.uid == request.resource.data.receiverId);
      allow update: if signedIn() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId);
      allow delete: if false;
    }

    match /hall_of_fame/{entryId} {
      allow read: if signedIn();
      allow create: if isClub() || isOwner(request.resource.data.playerId);
      allow update, delete: if false;
    }

    match /notifications/{notificationId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn();
      allow update: if signedIn() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    match /payments/{paymentId} {
      allow read, update: if signedIn() && request.auth.uid == resource.data.uid;
      allow create: if signedIn() && request.auth.uid == request.resource.data.uid;
      allow delete: if false;
    }

    match /typing/{typingId} {
      allow read, write: if signedIn();
      allow delete: if false;
    }
  }
}
